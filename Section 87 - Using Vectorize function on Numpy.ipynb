   "outputs": [],
   "source": [
    "def get_max(a, b):\n",
    "    if (a > b):\n",
    "        return a\n",
    "    \n",
    "    return b"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "f95afd83",
