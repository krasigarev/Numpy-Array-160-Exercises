     "text": [
      "[[7 4 5]\n",
      " [7 7 5]]\n"
     ]
    }
   ],
   "source": [
    "b_vectfunc = np.vectorize(get_max)\n",
    "x = [[1,2,3], [4,7,2]]\n",
    "y = [7,4,5]\n",
    "\n",
    "result = b_vectfunc(x,y)\n",
    "\n",
    "print(result)"
   ]
